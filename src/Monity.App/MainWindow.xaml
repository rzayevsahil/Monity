<Window x:Class="Monity.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Monity.App"
        mc:Ignorable="d"
        Title="Monity - App Usage Tracker"
        Height="600" Width="900"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: logo+isim solda, butonlar sağda (çakışmayı önlemek için iki sütun) -->
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}" Padding="16,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="1"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Image Source="pack://application:,,,/Assets/AppIcon.ico" Width="28" Height="28" Margin="0,0,8,0" Stretch="Uniform"/>
                    <TextBlock Text="{DynamicResource App_Name}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="UpdateBanner" Visibility="Collapsed" Background="{DynamicResource UpdateBannerBrush}" CornerRadius="6" Padding="10,6" Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtUpdateMessage" Text="{DynamicResource Main_NewVersion}" Foreground="{DynamicResource TextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button x:Name="BtnUpdate" Content="{DynamicResource Main_Update}" Style="{DynamicResource PrimaryButtonStyle}" Padding="10,6" Click="BtnUpdate_Click"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="BtnDashboard" Content="{DynamicResource Dashboard_Title}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Margin="0,0,6,0" Click="BtnDashboard_Click"/>
                    <Button x:Name="BtnBrowserTracking" Content="{DynamicResource Navigation_BrowserTracking}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Margin="0,0,6,0" Click="BtnBrowserTracking_Click"/>
                    <Button x:Name="BtnPomodoro" Content="{DynamicResource Navigation_Pomodoro}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Margin="0,0,6,0" Click="BtnPomodoro_Click"/>
                    <Button x:Name="BtnStatistics" Content="{DynamicResource Main_Statistics}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Margin="0,0,6,0" Click="BtnStatistics_Click"/>
                    <Button x:Name="BtnAchievements" Content="{DynamicResource Achievement_Title}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Margin="0,0,6,0" Click="BtnAchievements_Click"/>
                    <Button x:Name="BtnSettings" Content="{DynamicResource Main_Settings}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Margin="0,0,6,0" Click="BtnSettings_Click"/>
                    <Button x:Name="BtnAbout" Content="{DynamicResource About_Title}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Margin="0,0,6,0" Click="BtnAbout_Click"/>
                    <Button x:Name="BtnShare" ToolTip="{DynamicResource Share_Button}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Margin="0,0,6,0" Click="BtnShare_Click">
                        <Button.Content>
                            <TextBlock Text="&#xE72D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                        </Button.Content>
                    </Button>
                    <Button x:Name="BtnScreenshot" ToolTip="{DynamicResource Main_Screenshot}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Margin="0,0,6,0" Click="BtnScreenshot_Click">
                        <Button.Content>
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                        </Button.Content>
                    </Button>
                    <Button x:Name="BtnMinimizeToTray" ToolTip="{DynamicResource Main_HideWindow}" Style="{DynamicResource SecondaryButtonStyle}" Padding="8,6" Click="BtnMinimizeToTray_Click">
                        <Button.Content>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>

        <!-- Footer: version + developer -->
        <Border Grid.Row="2" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtFooterVersion" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                <TextBlock Text=" · " FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}">
                    <Run Text="{DynamicResource Main_Developer}"/>
                    <Hyperlink x:Name="LinkFooterDeveloper" RequestNavigate="LinkFooter_RequestNavigate"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
