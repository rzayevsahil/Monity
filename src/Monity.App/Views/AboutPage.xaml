<Page x:Class="Monity.App.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="600"
      Title="{DynamicResource About_Title}"
      Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header with Back Button -->
            <Grid Margin="0,0,0,24">
                <TextBlock Text="{DynamicResource About_Title}" 
                          FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                <Button Content="{DynamicResource Settings_Back}" 
                       Style="{DynamicResource SecondaryButtonStyle}"
                       HorizontalAlignment="Right" Click="BtnBack_Click"/>
            </Grid>
            
            <!-- App Identity Section -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" 
                   BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                   Padding="24" Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Center">
                    <!-- App Logo -->
                    <Image Source="pack://application:,,,/Assets/MonityLogo.png" 
                           Width="200" Height="200" Margin="0,0,0,20"
                           RenderOptions.BitmapScalingMode="HighQuality" 
                           Stretch="Uniform" StretchDirection="DownOnly"/>
                    
                    <!-- App Name -->
                    <TextBlock Text="{DynamicResource App_Name}" 
                              FontSize="28" FontWeight="Bold" 
                              HorizontalAlignment="Center" 
                              Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                    
                    <!-- App Description -->
                    <TextBlock Text="{DynamicResource About_AppDescription}" 
                              FontSize="14" 
                              HorizontalAlignment="Center" 
                              Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                    
                    <!-- Version Info -->
                    <TextBlock x:Name="TxtVersion" Text="v5.5.0" 
                               FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Center" 
                               Foreground="{DynamicResource PrimaryBrush}"/>
                </StackPanel>
            </Border>
            
            <!-- App Purpose Section -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" 
                   BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                   Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource About_Purpose}" 
                              FontSize="16" FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource About_PurposeDescription}" 
                              FontSize="13" TextWrapping="Wrap"
                              Foreground="{DynamicResource TextBrush}" LineHeight="20"/>
                </StackPanel>
            </Border>
            
            <!-- Features Section -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" 
                   BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                   Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource About_Features}" 
                              FontSize="16" FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <!-- Sağ sütundaki uzun metinler için biraz daha geniş alan -->
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature1}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature2}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature3}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature4}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature5}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature6}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature7}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature8}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature9}"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature10}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature11}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature12}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature13}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature14}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature15}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature16}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap">
                                <Run Text="• "/>
                                <Run Text="{DynamicResource About_Feature17}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Developer Section -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" 
                   BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                   Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource About_Developer}" 
                              FontSize="16" FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                    <StackPanel>
                        <!-- Developer Name -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource About_DeveloperName}" 
                                      FontSize="13" FontWeight="SemiBold" 
                                      Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Sahil Rzayev" 
                                      FontSize="13" Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                        
                        <!-- Contact Section -->
                        <TextBlock Text="{DynamicResource About_Contact}" 
                                  FontSize="13" FontWeight="SemiBold" 
                                  Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                        
                        <!-- Contact Links -->
                        <StackPanel Margin="16,0,0,0">
                            <!-- Email -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image Source="pack://application:,,,/Assets/email-icon.png" 
                                       Width="18" Height="18" Margin="0,0,8,0" 
                                       VerticalAlignment="Center"/>
                                <TextBlock Text="sahilrzayev200d@gmail.com" FontSize="13" 
                                          Foreground="{DynamicResource PrimaryBrush}" 
                                          Cursor="Hand" MouseLeftButtonUp="EmailLink_Click"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- GitHub -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image Source="pack://application:,,,/Assets/github-icon.png" 
                                       Width="20" Height="20" Margin="0,0,8,0" 
                                       VerticalAlignment="Center"/>
                                <TextBlock Text="rzayevsahil" FontSize="13" 
                                          Foreground="{DynamicResource PrimaryBrush}" 
                                          Cursor="Hand" MouseLeftButtonUp="GitHubLink_Click"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- LinkedIn -->
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/Assets/linkedin-icon.png" 
                                       Width="20" Height="20" Margin="0,0,8,0" 
                                       VerticalAlignment="Center"/>
                                <TextBlock Text="sahilrzayev" FontSize="13" 
                                          Foreground="{DynamicResource PrimaryBrush}" 
                                          Cursor="Hand" MouseLeftButtonUp="LinkedInLink_Click"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Version History Section: her sürüm başlık + maddeler (düzenli liste) -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" 
                   BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                   Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource About_VersionHistory}" 
                              FontSize="16" FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                    <StackPanel>
                        <!-- v5.5.0 -->
                        <TextBlock Text="{DynamicResource About_Ver_550}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                        <StackPanel Margin="16,0,0,10">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_550_1}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_550_2}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_550_3}"/></TextBlock>
                        </StackPanel>
                        <!-- v5.1.0 -->
                        <TextBlock Text="{DynamicResource About_Ver_510}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                        <StackPanel Margin="16,0,0,10">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_510_1}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_510_2}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_510_3}"/></TextBlock>
                        </StackPanel>
                        <!-- v5.0.0 -->
                        <TextBlock Text="{DynamicResource About_Ver_500}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                        <StackPanel Margin="16,0,0,10">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_500_1}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_500_2}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_500_3}"/></TextBlock>
                        </StackPanel>
                        <!-- v4.9.8 -->
                        <TextBlock Text="{DynamicResource About_Ver_498}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                        <StackPanel Margin="16,0,0,10">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_498_1}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_498_2}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_498_3}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_498_4}"/></TextBlock>
                        </StackPanel>
                        <!-- v4.9.0 -->
                        <TextBlock Text="{DynamicResource About_Ver_490}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                        <StackPanel Margin="16,0,0,10">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_490_1}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_490_2}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_490_3}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_490_4}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_490_5}"/></TextBlock>
                        </StackPanel>
                        <!-- v4.2.0 -->
                        <TextBlock Text="{DynamicResource About_Ver_420}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                        <StackPanel Margin="16,0,0,10">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_420_1}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_420_2}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_420_3}"/></TextBlock>
                        </StackPanel>
                        <!-- v4.1.0 -->
                        <TextBlock Text="{DynamicResource About_Ver_410}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                        <StackPanel Margin="16,0,0,10">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_410_1}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_410_2}"/></TextBlock>
                        </StackPanel>
                        <!-- v4.0.0 -->
                        <TextBlock Text="{DynamicResource About_Ver_400}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                        <StackPanel Margin="16,0,0,0">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_400_1}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"><Run Text="• "/><Run Text="{DynamicResource About_Ver_400_2}"/></TextBlock>
                            <TextBlock FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"><Run Text="• "/><Run Text="{DynamicResource About_Ver_400_3}"/></TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Copyright Section -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" 
                   BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                   Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{DynamicResource About_Copyright}" 
                              FontSize="12" HorizontalAlignment="Center"
                              Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
            
            <!-- Bottom Back Button -->
            <Button Content="{DynamicResource Settings_Back}" 
                   Style="{DynamicResource SecondaryButtonStyle}"
                   HorizontalAlignment="Left" Click="BtnBack_Click"/>
        </StackPanel>
    </ScrollViewer>
</Page>