<Window x:Class="Monity.App.Views.ShareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Share_Title}"
        Height="560" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <TextBlock Text="{DynamicResource Share_Period}" Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,0,0,8"/>
            <ComboBox x:Name="PeriodCombo" MinHeight="36" Margin="0,0,0,16"
                      Foreground="{DynamicResource TextBrush}" SelectionChanged="PeriodCombo_SelectionChanged"/>
            <TextBlock Text="{DynamicResource Share_Preview}" Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,0,0,8"/>
            <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,16">
                <Grid MinHeight="200">
                    <Image x:Name="PreviewImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                           MaxWidth="420" MaxHeight="220" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="TxtLoading" Text="{DynamicResource Share_Loading}" Foreground="{DynamicResource TextMutedBrush}" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <TextBlock Text="{DynamicResource Share_CaptionPreview}" Foreground="{DynamicResource TextBrush}" FontSize="14" Margin="0,0,0,8"/>
            <TextBox x:Name="TxtCaptionPreview" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="72" MaxHeight="120" VerticalScrollBarVisibility="Auto"
                     Padding="10,8" Margin="0,0,0,16"
                     Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
            <Button x:Name="BtnCopyImage" Content="{DynamicResource Share_CopyImage}" Style="{DynamicResource PrimaryButtonStyle}" Margin="0,0,0,10" Click="BtnCopyImage_Click" IsEnabled="False"/>
            <Button x:Name="BtnCopyText" Content="{DynamicResource Share_CopyText}" Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,0,10" Click="BtnCopyText_Click" IsEnabled="False"/>
            <Button x:Name="BtnSaveImage" Content="{DynamicResource Share_SaveImage}" Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,0,20" Click="BtnSaveImage_Click" IsEnabled="False"/>
            <TextBlock x:Name="TxtStatus" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</Window>
