<UserControl x:Class="Monity.App.Views.ShareCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             xmlns:local="clr-namespace:Monity.App.Views"
             mc:Ignorable="d"
             Width="1200" Height="630"
             d:DesignHeight="630" d:DesignWidth="1200"
             Background="{DynamicResource CardBrush}">
    <UserControl.Resources>
        <controls:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:BarWidthConverter x:Key="BarWidthConverter"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="48,40">
        <Grid>
            <!-- Arka plan: hafif logo -->
            <Image Source="pack://application:,,,/Assets/MonityLogo.png" Width="320" Height="320" Stretch="Uniform"
                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,80,0" Opacity="0.05"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header: sade logo + isim -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,28">
                    <Image Source="pack://application:,,,/Assets/MonityLogo.png" Width="56" Height="56" Stretch="Uniform"/>
                    <TextBlock Text="{Binding AppName}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>

                <!-- Ana alan: sol hero + sağ özet -->
                <Grid Grid.Row="1" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sol: tek odak (süre) + toplu meta bilgi -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" MaxWidth="520">
                        <StackPanel x:Name="ContentPanel">
                            <!-- Dönem · Tarih -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{Binding PeriodLabel}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text=" · " FontSize="14" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,2,0" Opacity="0.7"/>
                                <TextBlock Text="{Binding DateRangeText}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Opacity="0.9"/>
                            </StackPanel>

                            <!-- Hero: sadece toplam süre -->
                            <TextBlock Text="{Binding TotalDurationText}" FontSize="64" FontWeight="Light" Foreground="{DynamicResource TextBrush}"
                                       Margin="0,0,0,20" LineHeight="64"/>

                            <!-- Meta: ortalama + trend + en çok kullanılan (tek blok) -->
                            <StackPanel Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding AvgPerDayText}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Visibility="{Binding HasTrend, Converter={StaticResource BoolToVisibilityConverter}}"
                                               Text="{Binding TrendText}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" Margin="20,0,0,0" Opacity="0.85"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource Share_TopApp}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TopAppName}" FontSize="13" Foreground="{DynamicResource TextBrush}" FontWeight="Medium"
                                               VerticalAlignment="Center" Margin="6,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="320"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- En verimli saatler (varsa) -->
                            <TextBlock Text="{Binding PeakHoursText}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,0,12" TextWrapping="Wrap" Opacity="0.85"
                                       Visibility="{Binding PeakHoursText, Converter={StaticResource NullToVisibilityConverter}}"/>

                            <!-- İçgörü: blokquote tarzı (sadece sol çizgi) -->
                            <Border Visibility="{Binding PrimaryHighlight, Converter={StaticResource NullToVisibilityConverter}}"
                                    BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="3,0,0,0"
                                    Margin="0,0,0,16" Padding="12,0,0,0">
                                <TextBlock x:Name="TxtInsight" Text="{Binding PrimaryHighlight}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap" LineHeight="22" Opacity="0.95"/>
                            </Border>

                            <!-- Hedef (en altta, minimal) -->
                            <TextBlock Text="{Binding GoalStatusText}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="480" Opacity="0.8"
                                       Visibility="{Binding GoalStatusText, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtNoData" FontSize="22" Foreground="{DynamicResource TextMutedBrush}" Margin="0,12,0,0" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Sağ: tek panel, iki bölüm -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="20" Margin="24,0,0,108" VerticalAlignment="Stretch">
                        <StackPanel VerticalAlignment="Top">
                            <!-- Kategori dağılımı -->
                            <StackPanel x:Name="TopCategoryCard" Margin="0,0,0,20">
                                <TextBlock Text="{DynamicResource Share_Stat_CategoryDistribution}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" Opacity="0.9"/>
                                <TextBlock Text="{Binding TopCategoryName}" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SessionCountText}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding TopCategories}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,5" Opacity="0.9"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Top 3 uygulama -->
                            <StackPanel x:Name="TopAppsCard" Margin="0,0,0,20">
                                <TextBlock Text="{DynamicResource Share_Stat_TopApps}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8" Opacity="0.9"/>
                                <ItemsControl ItemsSource="{Binding TopAppBars}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="{Binding Label}" FontSize="13" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                                                <Border Height="5" CornerRadius="2.5" Margin="0,3,0,0" HorizontalAlignment="Left" MinWidth="16"
                                                        Width="{Binding BarWidthPercent, Converter={StaticResource BarWidthConverter}}"
                                                        Background="{DynamicResource PrimaryBrush}" Opacity="0.6"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Öne çıkanlar -->
                            <StackPanel x:Name="HighlightsCard">
                                <TextBlock Text="{DynamicResource Share_Stat_Highlights}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8" Opacity="0.9"/>
                                <ItemsControl ItemsSource="{Binding Highlights}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" TextWrapping="Wrap" Opacity="0.95"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="0,0,0,0">
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,14" Opacity="0.6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding AppName}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Opacity="0.85"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Share_Developer}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.8"/>
                            <TextBlock Text="{Binding DeveloperName}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock Text="GitHub" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.8"/>
                            <TextBlock Text="{Binding GitHubDisplay}" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock Text="LinkedIn" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.8"/>
                            <TextBlock Text="{Binding LinkedInDisplay}" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
