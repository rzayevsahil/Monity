<UserControl x:Class="Monity.App.Views.ShareCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             xmlns:local="clr-namespace:Monity.App.Views"
             mc:Ignorable="d"
             Width="1200" Height="630"
             d:DesignHeight="630" d:DesignWidth="1200"
             Background="{DynamicResource CardBrush}">
    <UserControl.Resources>
        <controls:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:BarWidthConverter x:Key="BarWidthConverter"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="40,36">
        <Grid>
            <!-- Sağ tarafta hafif watermark (boş alanı doldurur) -->
            <Image Source="pack://application:,,,/Assets/MonityLogo.png" Width="280" Height="280" Stretch="Uniform"
                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,60,0" Opacity="0.07"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header: logo + app name (logo büyütüldü) -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,20">
                    <Image Source="pack://application:,,,/Assets/MonityLogo.png" Width="76" Height="76" Stretch="Uniform"/>
                    <TextBlock Text="{Binding AppName}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="20,0,0,0"/>
                </StackPanel>

                <!-- Main content: sol (ana metrik) + sağ (mini istatistikler) -->
                <Grid Grid.Row="1" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="380"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: primary metric (sade, net hiyerarşi) -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left">
                        <StackPanel x:Name="ContentPanel" HorizontalAlignment="Left">
                            <!-- Dönem + tarih tek satır -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="{Binding PeriodLabel}" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text=" · " FontSize="16" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                <TextBlock Text="{Binding DateRangeText}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Opacity="0.85"/>
                            </StackPanel>
                            <!-- Ana vurgu: toplam süre -->
                            <TextBlock Text="{Binding TotalDurationText}" FontSize="52" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2" LineHeight="52"/>
                            <!-- Trend (varsa) ve günlük ortalama tek blokta -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="{Binding AvgPerDayText}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Visibility="{Binding HasTrend, Converter={StaticResource BoolToVisibilityConverter}}" Text="{Binding TrendText}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="16,0,0,0" Opacity="0.9"/>
                            </StackPanel>
                            <!-- En çok kullanılan: tek satır, dengeli tipografi -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Share_TopApp}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding TopAppName}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                            </StackPanel>
                            <!-- En verimli saatler (varsa, küçük) -->
                            <TextBlock Text="{Binding PeakHoursText}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8" TextWrapping="Wrap" MaxWidth="520"
                                       Visibility="{Binding PeakHoursText, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <!-- İçgörü kutusu: tek öne çıkan kutu -->
                            <Border Visibility="{Binding PrimaryHighlight, Converter={StaticResource NullToVisibilityConverter}}" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,2,0,0" MaxWidth="560" HorizontalAlignment="Left">
                                <TextBlock x:Name="TxtInsight" Text="{Binding PrimaryHighlight}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="20"/>
                            </Border>
                            <!-- Hedef: tek satır, ikincil bilgi -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" Visibility="{Binding GoalStatusText, Converter={StaticResource NullToVisibilityConverter}}">
                                <TextBlock Text="{Binding GoalStatusText}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" MaxWidth="380" VerticalAlignment="Center" Opacity="0.9"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock x:Name="TxtNoData" FontSize="24" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Right: secondary stats -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="20,0,0,0">
                        <Border x:Name="TopCategoryCard" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Share_Stat_CategoryDistribution}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding TopCategoryName}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,2,0,6"/>
                                <TextBlock Text="{Binding SessionCountText}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding TopCategories}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border x:Name="TopAppsCard" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Share_Stat_TopApps}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding TopAppBars}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Label}" FontSize="13" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                                                <Border Height="6" CornerRadius="3" Margin="0,2,0,0" HorizontalAlignment="Left" MinWidth="20"
                                                        Width="{Binding BarWidthPercent, Converter={StaticResource BarWidthConverter}}"
                                                        Background="{DynamicResource PrimaryBrush}" Opacity="0.7"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border x:Name="HighlightsCard" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Share_Stat_Highlights}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding Highlights}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Footer: ayırıcı çizgi + uygulama adı + geliştirici bilgisi -->
                <StackPanel Grid.Row="2" Margin="0,0,0,0">
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding AppName}" FontSize="15" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Share_Developer}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding DeveloperName}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="GitHub" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding GitHubDisplay}" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="LinkedIn" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding LinkedInDisplay}" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
